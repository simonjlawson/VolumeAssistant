<Window x:Class="VolumeAssistant.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VolumeAssistant"
        Width="840" Height="520"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="White">

    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="#555" BorderThickness="1,1,1,0"
                                Margin="2,0,2,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#888"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="#1E1E1E" BorderBrush="#444"
                    Foreground="White" Margin="8">

            <!-- Connection Tab -->
            <TabItem Header="Connection">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                    <StackPanel Margin="16" x:Name="ConnectionPanel">

                        <TextBlock Text="Cambridge Audio" FontWeight="Bold" FontSize="14"
                                   Foreground="White" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Status:"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CaStatusText"
                                       Text="Disabled" VerticalAlignment="Center"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Host:"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CaHostText"
                                       Text="—" VerticalAlignment="Center"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Device:"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CaDeviceText"
                                       Text="—" VerticalAlignment="Center"/>

                            <Label Grid.Row="3" Grid.Column="0" Content="Zone:"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CaZoneText"
                                       Text="—" VerticalAlignment="Center"/>

                            <Label Grid.Row="4" Grid.Column="0" Content="Volume:"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CaVolumeText"
                                       Text="—" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,8">
                            <Button x:Name="CaConnectButton" Content="Connect" Padding="10,4" Margin="0,0,0,0"
                                    Click="CaConnectButton_Click" Background="#1E90FF" Foreground="White" BorderBrush="#0B61A4"/>
                        </StackPanel>

                        <Separator Background="#444" Margin="0,16"/>

                        <TextBlock Text="Windows Audio" FontWeight="Bold" FontSize="14"
                                   Foreground="White" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Volume:"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="WinVolumeText"
                                       Text="—" VerticalAlignment="Center"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Muted:"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="WinMutedText"
                                       Text="—" VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Configuration Tab -->
            <TabItem Header="Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                    <StackPanel Margin="16" x:Name="ConfigPanel">

                        <TextBlock Text="Cambridge Audio Settings" FontWeight="Bold" FontSize="14"
                                   Foreground="White" Margin="0,0,0,8"/>

                        <Grid x:Name="ConfigGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        </Grid>

                        <StackPanel Margin="0,12,0,0">
                            <Separator Background="#444" Margin="0,6"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                <Button x:Name="ReloadConfigButton" Content="Reload" Padding="8,4" Margin="0,0,8,0"
                                        Click="ReloadConfig_Click" Background="#333" Foreground="White" BorderBrush="#555"/>
                                <Button x:Name="SaveConfigButton" Content="Save" Padding="8,4" Click="SaveConfig_Click"
                                        Background="#1E90FF" Foreground="White" BorderBrush="#0B61A4"/>
                            </StackPanel>

                            <TextBlock Text="appsettings.json location" FontWeight="Bold" Foreground="White"
                                       Margin="0,6,0,4"/>
                            <TextBlock x:Name="AppSettingsPathText" Text="—" TextWrapping="Wrap"
                                       Foreground="#AAAAAA"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Logs Tab -->
            <TabItem Header="Logs">
                <Grid Background="#1E1E1E">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0" x:Name="LogListBox"
                             Background="#141414" Foreground="#CCCCCC"
                             BorderBrush="#444" BorderThickness="1"
                             Margin="8,8,8,4"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="11"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    <Button Grid.Row="1" Content="Clear Logs" HorizontalAlignment="Right"
                            Margin="8,4,8,8" Padding="10,4"
                            Background="#333" Foreground="White" BorderBrush="#555"
                            Click="ClearLogs_Click"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="1" Background="#252525" BorderBrush="#444" BorderThickness="0,1,0,0" Padding="8,4">
            <TextBlock x:Name="StatusBarText" Text="Running" Foreground="#AAAAAA" FontSize="11"/>
        </Border>
    </Grid>
</Window>
